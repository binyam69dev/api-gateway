# ============================================
# API GATEWAY - DEVELOPMENT ENVIRONMENT
# ============================================

# ============ SERVER ============
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
EMAIL_LOGIN_ENABLED=true
USE_COOKIES=true

# ============ JWT SECURITY ============
JWT_SECRET=your-jwt-secret-min-32-characters
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=your-session-secret-min-32-characters

# ============ DATABASE (Local Docker) ============
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=api_gateway
POSTGRES_USER=gateway_admin
POSTGRES_PASSWORD=SecurePass123!

# ============ REDIS ============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============ RATE LIMITING ============
DEFAULT_RATE_LIMIT=100
DEFAULT_RATE_WINDOW_MS=60000

# ============ CACHING ============
DEFAULT_CACHE_TTL_SECONDS=60

# ============ PROXY ============
PROXY_TIMEOUT_MS=30000
PROXY_RETRY_COUNT=3

# ============ COOKIE SETTINGS (Development) ============
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=false
COOKIE_SAME_SITE=lax

# ============ OAUTH - Google ============
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
DEV_GOOGLE_CLIENT_ID=your_dev_google_client_id
DEV_GOOGLE_CLIENT_SECRET=your_dev_google_client_secret

# ============ OAUTH - GitHub ============
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
DEV_GITHUB_CLIENT_ID=your_dev_github_client_id
DEV_GITHUB_CLIENT_SECRET=your_dev_github_client_secret

# ============ OAUTH - Facebook ============
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
DEV_FACEBOOK_APP_ID=your_dev_facebook_app_id
DEV_FACEBOOK_APP_SECRET=your_dev_facebook_app_secret